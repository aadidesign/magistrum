# LLM provider — "groq" (sample mode) or "ollama" (production VPS)
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true
MONGODB_DB_NAME=pitch_magistrum

# Brevo transactional email
BREVO_API_KEY=xkeysib-xxx
BREVO_FROM_EMAIL=pitches@yourdomain.com
BREVO_TO_EMAIL=you@yourdomain.com

# RAG
KB_PATH=./kb
CHROMA_PATH=./chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Operations
SAMPLE_MODE=true
ALLOWED_ORIGINS=http://localhost:3000,https://magistrum-pitch.vercel.app
